# ── Farcaster ─────────────────────────────────────────────
NEYNAR_API_KEY=your_neynar_api_key
NEYNAR_WEBHOOK_SECRET=your_neynar_webhook_secret
FARCASTER_APP_MNEMONIC=your_app_mnemonic_for_write_access

# ── Database (Neon Postgres with pgvector) ────────────────
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── AI ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key   # for embeddings (text-embedding-3-small)

# ── Blockchain (Base) ─────────────────────────────────────
ALCHEMY_API_KEY=your_alchemy_api_key
ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
MARKETPLACE_WALLET_PRIVATE_KEY=your_marketplace_wallet_key

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.xyz
NEXT_PUBLIC_APP_NAME=TwinMarket
JWT_SECRET=your_jwt_secret_min_32_chars
